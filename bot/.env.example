# ──────────────────────────────────────────────
# LionBrain Bot — 設定檔
# 複製這個檔案，重命名為 .env，填入你的資料
# ──────────────────────────────────────────────

# Telegram Bot Token（從 @BotFather 取得）
TELEGRAM_TOKEN=你的_bot_token_放這裡

# 你的 Telegram Chat ID
# 步驟：先啟動 bot，發送任意訊息，再發 /myid 取得
TELEGRAM_CHAT_ID=你的_chat_id_放這裡

# Gemini API Key（從 Google AI Studio 取得）
GEMINI_API_KEY=你的_gemini_api_key_放這裡

# LionBrain 資料夾完整路徑（不要加結尾的 \）
LIONBRAIN_PATH=C:\Users\Administrator\Desktop\LionBrain

# Gemini 模型（預設 gemini-2.0-flash，可改 gemini-1.5-flash）
GEMINI_MODEL=gemini-2.0-flash

# 早報推送時間（24小時制，預設 08:00）
MORNING_HOUR=8
MORNING_MINUTE=0
