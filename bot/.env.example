# ──────────────────────────────────────────────
# 群獅管家 Bot — 環境變數設定
# 複製此檔為 .env，填入真實值
# ──────────────────────────────────────────────

# Telegram Bot Token（從 @BotFather 取得）
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# 你的 Telegram Chat ID（傳訊息給 Bot 後發 /myid 取得）
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Gemini API Key（從 Google AI Studio 取得：aistudio.google.com）
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Gemini 模型（建議使用 gemini-2.5-flash）
GEMINI_MODEL=gemini-2.5-flash

# Claude API Key（從 console.anthropic.com 取得）
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# GitHub Token（需有此 repo 的讀寫權限）
GITHUB_TOKEN=YOUR_GITHUB_TOKEN

# GitHub Repo 資訊
GITHUB_OWNER=YOUR_GITHUB_USERNAME
GITHUB_REPO=YOUR_REPO_NAME

# 早報推送時間（24小時制）
MORNING_HOUR=8
MORNING_MINUTE=0
